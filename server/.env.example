# ──────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────
PORT=3000

# ──────────────────────────────────────────────
# Billing
# ──────────────────────────────────────────────
# Free credits granted once when a user billing account is first created.
BILLING_SIGNUP_CREDITS=100
# Optional database override, useful for tests or a mounted production volume.
# DATABASE_PATH=./data/database.db

# Stripe Checkout (recommended). Keep all three values server-side. The
# publishable key is recorded for future embedded Elements support; hosted
# Checkout currently uses only the secret key and verified webhook.
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# FRONTEND_URL=http://localhost:5173
# Webhook endpoint: POST /billing/webhooks/stripe

# Generic hosted payment fallback. The backend replaces {orderId} with the
# server-created order id and redirects the browser to the resulting HTTPS URL.
# Leave unset to keep purchase buttons visibly disabled (no simulated payment).
# PAYMENT_CHECKOUT_URL_TEMPLATE=https://pay.example.com/checkout?order_id={orderId}
# PAYMENT_PROVIDER_NAME=hosted_checkout

# ──────────────────────────────────────────────
# AI Provider — OpenAI-compatible (Required)
# ──────────────────────────────────────────────
# Your primary OpenAI (or compatible) API key and base URL.
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ──────────────────────────────────────────────
# AI Provider — Google Gemini (Optional)
# ──────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ──────────────────────────────────────────────
# AI Provider — Yunwu / 云雾 API (Optional)
# ──────────────────────────────────────────────
# Yunwu is an optional third-party AI gateway that provides unified access
# to multiple model providers. If configured, it takes priority over the
# default OpenAI key for the corresponding purpose.
#
# Unified key (used as fallback for all purposes):
# API_KEY=
# YUNWU_API_KEY=
#
# Purpose-specific keys (take priority over the unified key):
# CHAT_API_KEY=            # or YUNWU_CHAT_API_KEY — for LLM chat completions
# IMAGE_API_KEY=           # or YUNWU_IMAGE_API_KEY — for image generation
# YUNWU_VIDEO_API_KEY=     # for video generation

# Video generation safeguards. Polling has a real wall-clock deadline; input
# references and downloaded outputs are rejected when they exceed these limits.
# VIDEO_GENERATION_TIMEOUT_MS=300000
# MAX_VIDEO_REFERENCE_SIZE=10485760
# MAX_VIDEO_SIZE=524288000

# ──────────────────────────────────────────────
# Baidu AI — image process (optional)
# ──────────────────────────────────────────────
# Used for canvas HD upscale (图像无损放大). When both keys are set, upscale
# uses Baidu by default instead of local RealESRGAN.
# Docs: https://cloud.baidu.com/doc/IMAGEPROCESS/s/ok3bclnkg
# BAIDU_API_KEY=your_baidu_api_key
# BAIDU_SECRET_KEY=your_baidu_secret_key
# Force provider: baidu | local  (default: baidu if keys set, else local)
# UPSCALE_PROVIDER=baidu

# ──────────────────────────────────────────────
# File Upload Configuration
# ──────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./files

# ──────────────────────────────────────────────
# Image Host (Optional)
# ──────────────────────────────────────────────
# Used to upload local references and generated screenshots so remote vision
# models can access them. The bundled integration uses multipart/form-data.
IMAGE_HOST_UPLOAD_URL=https://img.scdn.io/api/v1.php
IMAGE_HOST_API_KEY=
IMAGE_HOST_CDN_DOMAIN=cloudflareimg.cdn.sn
IMAGE_HOST_STORAGE_DESTINATION=local

# ──────────────────────────────────────────────
# Unsplash API (Optional)
# ──────────────────────────────────────────────
# Enables real image search in the collect_inspiration tool.
# Get a free key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ──────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────
# Web Search — Tavily (Optional)
# ──────────────────────────────────────────────
# Enables the agent to search the web for real-time information.
# Free tier: 1000 requests/month. Get your key at https://tavily.com
# TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=replace-with-at-least-32-random-bytes

# ──────────────────────────────────────────────
# Mock Mode
# ──────────────────────────────────────────────
# Set to true to bypass real API calls (useful for development without API credits)
MOCK_AGENT=false
MOCK_IMAGE_GENERATION=false
MOCK_VIDEO=false

# ──────────────────────────────────────────────
# Google Sign-In Authentication (Optional)
# ──────────────────────────────────────────────
# Retrieve your Google Client ID from Google Cloud Console.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# STRIPE CONFIGURATION
# 支付成功：4242 4242 4242 4242
# 需要 3D Secure 验证：4000 0000 0000 3220
# 支付被拒绝：4000 0000 0000 0002
# 余额不足：4000 0000 0000 9995
# 其他字段随便填写：
# 有效期：任意未来日期，例如 12/34
# CVC：任意三位数，例如 123
# 姓名、邮编：任意内容
# stripe listen --forward-to localhost:3000/billing/webhooks/stripe
STRIPE_SECRET_KEY=<测试私钥>
STRIPE_PUBLISHABLE_KEY=<测试公钥>
STRIPE_WEBHOOK_SECRET=<whsec_...>
FRONTEND_URL=http://localhost:5173
