# Server Configuration
PORT=3000

# OpenAI API Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini API Configuration (Optional)
GOOGLE_API_KEY=your_google_api_key_here

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./files

# Image Host (optional) - used to upload generated screenshots so the vision model can
# access them via URL. If left empty, the app falls back to inline base64.
IMAGE_HOST_UPLOAD_URL=
IMAGE_HOST_API_KEY=

# Unsplash API (optional) - enables real image search in collect_inspiration tool.
# Get a free key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Security
NODE_ENV=development

# Mock mode — set to true to bypass real LLM calls (no API credits needed)
MOCK_AGENT=false

# Mock image generation — set to true to bypass real image generation calls (uses color block placeholders)
MOCK_IMAGE_GENERATION=false

# Mock video generation — set to true to bypass real video generation calls (uses local FFmpeg mock video)
MOCK_VIDEO=false

